# Backend Server Configuration
PORT=4000

# Email Notification Configuration (Optional - leave blank to disable)
# For Gmail: Use App Password (not regular password)
# For other providers: Use your SMTP credentials

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=your-email@gmail.com

# Example for other providers:
# Outlook/Office365:
#   EMAIL_HOST=smtp.office365.com
#   EMAIL_PORT=587
#   EMAIL_SECURE=false

# SendGrid:
#   EMAIL_HOST=smtp.sendgrid.net
#   EMAIL_PORT=587
#   EMAIL_SECURE=false
#   EMAIL_USER=apikey
#   EMAIL_PASS=SG.your-sendgrid-key

# Note: If EMAIL_HOST and EMAIL_USER are not set, email notifications will be disabled
# and the system will log a message indicating SMTP is not configured.
